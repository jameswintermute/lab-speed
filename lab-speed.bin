#!/usr/bin/env bash
# lab-speed — rapid lab setup utility
# v1.3.0 — Mar 2026 — James Wintermute
#
# Changes from v1.2.0:
#   - rsync: dropped -z (compression) — measurably faster on high-bandwidth cloud links
#   - rsync -e: SSH_OPTS now quoted via printf %q — safe for paths containing spaces
#   - ssh_menu: replaced unsafe eval with a direct sshpass/ssh array call
#   - SSH GUI terminals: command passed via self-deleting temp script — no nested-quote fragility
#   - open_ssh_terminal: added xterm, alacritty, wezterm support; graceful gnome-terminal
#     --title fallback (newer gnome-terminal versions dropped the flag)
#   - header(): sets terminal window/tab title via ANSI escape (\033]0;...\007)
#   - ssh_menu: sets per-host title while session is active; restores lab-speed on return
#   - Parallel subshell stdout/stderr redirected to /dev/null — progress bar stays clean
#   - Progress polling: shopt nullglob used in-scope — no spurious *.result glob errors
#   - Elapsed time now shown in GO!/RSYNC completion message
#   - Log rotation: bash loop + mapfile replaces xargs — safe when ≤20 logs exist
#   - SSH_OPTS: added ServerAliveInterval/CountMax — detects dead connections (~45s max hang)
#   - Menu: option 1 text corrected; option 4 = Install SSH keys (new); dep check → option 5
set -Eeuo pipefail

# ─────────────────────────────────── Colors ─────────────────────────────────
CLR_MAG="\033[35m"; CLR_GRN="\033[32m"; CLR_RED="\033[31m"
CLR_YEL="\033[33m"; CLR_CYN="\033[36m"; CLR_RST="\033[0m"

# ─────────────────────────────────── Paths ──────────────────────────────────
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
LOCAL_DIR="$ROOT_DIR/local"
LOGS_DIR="$ROOT_DIR/logs"
FILES_DIR="$ROOT_DIR/files-to-copy"
HOSTS_FILE="$LOCAL_DIR/hosts.csv"
CREDS_FILE="$LOCAL_DIR/credentials.txt"
KNOWN_HOSTS_FILE="$ROOT_DIR/.known_hosts"
TARGET_DIR="/tmp/lab-speed"
mkdir -p "$LOCAL_DIR" "$LOGS_DIR" "$FILES_DIR"

RUN_TAG="$(date +%Y%m%d-%H%M%S)-$$"
RUN_LOG="$LOGS_DIR/lab-speed-$RUN_TAG.log"

# ─────────────────────── SSH options (single definition) ────────────────────
# All ssh / rsync / ssh-copy-id calls use this array — change timeouts here only.
SSH_OPTS=(
  -o PreferredAuthentications=password
  -o PubkeyAuthentication=no
  -o NumberOfPasswordPrompts=1
  -o StrictHostKeyChecking=accept-new
  -o "UserKnownHostsFile=$KNOWN_HOSTS_FILE"
  -o ConnectTimeout=10
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=3
)

# ─────────────────────────────── ASCII banner ───────────────────────────────
header() {
  clear
  printf '\033]0;lab-speed\007'   # set terminal window/tab title
  printf "%b" "$CLR_MAG"
  printf "%s\n" " ╻  ┏━┓┏┓    ┏━┓┏━┓┏━╸┏━╸╺┳┓╻"
  printf "%s\n" " ┃  ┣━┫┣┻┓   ┗━┓┣━┛┣╸ ┣╸  ┃┃╹"
  printf "%s\n" " ┗━╸╹ ╹┗━┛   ┗━┛╹  ┗━╸┗━╸╺┻┛╹"
  printf "\n%s\n" "      A rapid lab setup utility"
  printf "\n%s\n" "      v1.3.0 - Mar 2026. James Wintermute"
  printf "%b\n" "$CLR_RST"
}

# ───────────────────────────────── Logging ──────────────────────────────────
log()      { printf "%b[%s]%b %s\n"   "$CLR_CYN" "$1" "$CLR_RST" "$2" | tee -a "$RUN_LOG"; }
log_ok()   { printf "%b[OK]%b %s\n"   "$CLR_GRN"      "$CLR_RST" "$1" | tee -a "$RUN_LOG"; }
log_warn() { printf "%b[WARN]%b %s\n" "$CLR_YEL"      "$CLR_RST" "$1" | tee -a "$RUN_LOG"; }
log_err()  { printf "%b[ERR]%b %s\n"  "$CLR_RED"      "$CLR_RST" "$1" | tee -a "$RUN_LOG"; }
die()      { log_err "$1"; exit 1; }

# ──────────────────────────── Trim whitespace + CR ──────────────────────────
trim() {
  local s="$1"
  s="${s//$'\r'/}"
  s="${s#${s%%[![:space:]]*}}"
  s="${s%${s##*[![:space:]]}}"
  printf "%s" "$s"
}

# ──────────────────────────────── Progress bar ──────────────────────────────
progress_bar() {
  local cur="$1" total="$2" label="$3"
  local width=30
  local filled=$(( (cur * width) / (total == 0 ? 1 : total) ))
  local empty=$(( width - filled ))
  local bar
  bar="$(printf '%*s' "$filled" '' | tr ' ' '#')$(printf '%*s' "$empty" '' | tr ' ' '-')"
  printf "\r  [%s] %d/%d %s" "$bar" "$cur" "$total" "$label"
}

# ──────────────────────────────── Log rotation ──────────────────────────────
rotate_logs() {
  # Keep the 20 most recent log files; safely remove older ones via a bash loop
  # (avoids the xargs-with-empty-input edge case on some systems).
  local -a old_logs
  mapfile -t old_logs < <(ls -t "$LOGS_DIR"/lab-speed-*.log 2>/dev/null | tail -n +21)
  if (( ${#old_logs[@]} > 0 )); then
    rm -f -- "${old_logs[@]}"
  fi
}

# ──────────────────────────────── Credentials ───────────────────────────────
ensure_creds() {
  if [[ ! -f "$CREDS_FILE" ]]; then
    mkdir -p "$LOCAL_DIR"
    cat >"$CREDS_FILE" <<'CRED'
# lab-speed credentials (chmod 600)
username=""
password=""
SSHPASS=""   # must match password; read by sshpass -e
CRED
    chmod 600 "$CREDS_FILE"
  fi

  # shellcheck disable=SC1090
  set +u; source "$CREDS_FILE"; set -u

  username="${username:-}"
  password="${password:-}"
  SSHPASS="${SSHPASS:-}"

  if [[ -z "$username" || -z "$password" ]]; then
    log "INFO" "Credentials missing — prompting and saving to $CREDS_FILE"
    read -r -p "  Lab username: " username
    read -r -s -p "  Lab password: " password; echo
    SSHPASS="${SSHPASS:-$password}"
    {
      echo "# lab-speed credentials (chmod 600)"
      printf 'username=%q\n' "$username"
      printf 'password=%q\n' "$password"
      printf 'SSHPASS=%q\n'  "$SSHPASS"
    } >"$CREDS_FILE"
    chmod 600 "$CREDS_FILE"
  fi

  # Ensure SSHPASS is always set — sshpass -e reads this env var
  [[ -z "$SSHPASS" ]] && SSHPASS="$password"
  export SSHPASS
}

# ───────────────────────────────── Hosts file ───────────────────────────────
ensure_hosts() {
  if [[ ! -f "$HOSTS_FILE" ]]; then
    mkdir -p "$LOCAL_DIR"
    cat >"$HOSTS_FILE" <<'CSV'
host-url,external-ip,internal-ip,function
https://example-cm,1.2.3.4,10.0.0.1,Splunk-CM
CSV
  fi
}

# ─────────────────────────────── Dependency check ───────────────────────────
check_deps() {
  local missing=0
  for c in ssh rsync awk sed sshpass; do
    if ! command -v "$c" >/dev/null 2>&1; then
      log_err "Missing required dependency: $c"
      missing=1
    else
      log_ok "$c"
    fi
  done
  # ssh-copy-id is optional — only needed for option 4 (key install)
  if command -v ssh-copy-id >/dev/null 2>&1; then
    log_ok "ssh-copy-id (optional — key install available via option 4)"
  else
    log_warn "ssh-copy-id not found — option 4 (SSH key install) unavailable"
  fi
  if (( missing )); then
    echo
    log "INFO" "Install (Ubuntu/Debian): sudo apt-get update && sudo apt-get install -y openssh-client rsync gawk sed sshpass"
    exit 1
  fi
}

# ───────────────────────────────── Read hosts ───────────────────────────────
# Finds external-ip and function columns by header name — not hardcoded position.
# Supports both external-ip and external_ip header variants.
read_hosts() {
  awk -F',' '
    NR==1 {
      for (i=1; i<=NF; i++) {
        gsub(/\r/, "", $i)
        h = tolower($i)
        if (h == "external-ip" || h == "external_ip") ip_col = i
        if (h == "function") fn_col = i
      }
    }
    NR>1 && ip_col && fn_col {
      gsub(/\r/, "", $ip_col)
      gsub(/\r/, "", $fn_col)
      if ($ip_col != "") print $ip_col "," $fn_col
    }
  ' "$HOSTS_FILE" | sed '/^[[:space:]]*$/d'
}

# ──────────────────────────── Rsync to one host ─────────────────────────────
rsync_to_host() {
  local ip="$1" func="$2"
  ip="$(trim "$ip")"; func="$(trim "$func")"

  if [[ -z "$ip" ]]; then
    log_warn "Skipping ${func}: empty IP address"
    return 1
  fi
  if [[ ! "$ip" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
    log_warn "${func}: '$ip' doesn't look like an IPv4 address — attempting anyway"
  fi

  # Build rsync -e argument with properly shell-quoted SSH options.
  # printf %q ensures paths with spaces (e.g. UserKnownHostsFile) are handled correctly.
  # -z (compression) is intentionally omitted — it adds CPU overhead on both sides and
  # is a net slowdown on the high-bandwidth links typical of cloud lab environments.
  local ssh_e
  ssh_e="ssh$(printf ' %q' "${SSH_OPTS[@]}")"

  if sshpass -e rsync -a --delete --mkpath \
      -e "$ssh_e" \
      "$FILES_DIR/" "${username}@${ip}:$TARGET_DIR/" 2>/dev/null; then
    return 0
  fi

  # Fallback for rsync < 3.2.3 (no --mkpath): create remote directory first,
  # then rsync. Costs one extra SSH connection per host but is fully compatible.
  sshpass -e ssh "${SSH_OPTS[@]}" "${username}@${ip}" \
    "mkdir -p '$TARGET_DIR'" 2>/dev/null || return 1

  sshpass -e rsync -a --delete \
    -e "$ssh_e" \
    "$FILES_DIR/" "${username}@${ip}:$TARGET_DIR/" 2>/dev/null
}

# ────────────────── Parallel provision (GO! and RSYNC again) ────────────────
# Runs all rsync jobs concurrently. Results written to a temp dir so the
# summary is accurate even with parallel output.
_run_parallel() {
  local label="$1"
  mapfile -t hosts < <(read_hosts)
  local total="${#hosts[@]}"
  (( total > 0 )) || die "No hosts found in $HOSTS_FILE"

  log "INFO" "$label starting — provisioning $total host(s) in parallel (→ $TARGET_DIR)"

  local tmpdir; tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  local t_start; t_start="$(date +%s)"

  # Launch all rsync jobs in the background.
  # Redirect subshell stdout/stderr to /dev/null — keeps the progress bar clean.
  # Log writes (via tee) still land in $RUN_LOG even with stdout suppressed.
  local pids=() line ip func
  for line in "${hosts[@]}"; do
    IFS=',' read -r ip func <<<"$line"
    ip="$(trim "$ip")"; func="$(trim "$func")"
    (
      if rsync_to_host "$ip" "$func"; then
        printf "ok:%s:%s\n"   "$func" "$ip" >"$tmpdir/${func//\//_}.result"
      else
        printf "fail:%s:%s\n" "$func" "$ip" >"$tmpdir/${func//\//_}.result"
      fi
    ) >/dev/null 2>&1 &
    pids+=($!)
  done

  # Poll for completion.
  # shopt nullglob is scoped to this block: *.result won't expand to a literal
  # string when no files exist yet, preventing spurious loop iterations.
  shopt -s nullglob
  local done_count=0
  while (( done_count < total )); do
    local result_files=("$tmpdir"/*.result)
    done_count="${#result_files[@]}"
    progress_bar "$done_count" "$total" "syncing..."
    sleep 0.25
  done
  shopt -u nullglob
  echo

  # Reap all background jobs cleanly
  for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  local t_end elapsed
  t_end="$(date +%s)"; elapsed=$(( t_end - t_start ))

  # Tally results and surface any per-host failures
  local ok=0 fail=0 result_file
  for result_file in "$tmpdir"/*.result; do
    [[ -f "$result_file" ]] || continue
    local result; result="$(cat "$result_file")"
    case "$result" in
      ok:*)   ok=$(( ok + 1 )) ;;
      fail:*) fail=$(( fail + 1 ))
              local fhost; fhost="${result#fail:}"
              log_warn "${fhost%%:*} (${fhost##*:}): rsync failed — check credentials / SSH access" ;;
    esac
  done

  if (( fail == 0 )); then
    log_ok "$label complete — ${ok}/${total} hosts ready in ${elapsed}s."
  else
    log_warn "$label finished — ${ok}/${total} OK, ${fail} failed in ${elapsed}s. See: $RUN_LOG"
  fi
}

go_run() {
  ensure_hosts
  ensure_creds
  check_deps
  _run_parallel "GO"
  log "INFO" "Next: choose option 2 to open SSH sessions."
}

rsync_only() {
  # Skips ensure_creds / check_deps when GO! has already been run this session.
  # Falls back gracefully if the user jumps straight to option 3.
  [[ -z "${SSHPASS:-}" ]] && ensure_creds
  ensure_hosts
  _run_parallel "RSYNC"
}

# ──────────────────────────── SSH key installation ──────────────────────────
# Installs your local SSH public key to all hosts in parallel via ssh-copy-id.
# After this, SSH connections no longer require sshpass (use option 2 normally
# — it will fall through to key auth automatically once sshpass is unavailable).
install_ssh_keys() {
  ensure_hosts
  ensure_creds

  if ! command -v ssh-copy-id >/dev/null 2>&1; then
    log_err "ssh-copy-id not found. Install: sudo apt-get install -y openssh-client"
    return 1
  fi

  # Find or generate a local keypair
  local key_file="$HOME/.ssh/id_rsa"
  if [[ ! -f "$key_file" ]]; then
    log "INFO" "No SSH key at $key_file — generating RSA 4096 keypair"
    ssh-keygen -t rsa -b 4096 -N "" -f "$key_file" -q
    log_ok "Keypair created: $key_file"
  fi
  local pub_key="${key_file}.pub"
  [[ -f "$pub_key" ]] || die "Public key not found: $pub_key"

  mapfile -t hosts < <(read_hosts)
  local total="${#hosts[@]}"
  (( total > 0 )) || die "No hosts found in $HOSTS_FILE"

  log "INFO" "Installing SSH public key to $total host(s) in parallel..."

  local tmpdir; tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  local pids=() line ip func
  for line in "${hosts[@]}"; do
    IFS=',' read -r ip func <<<"$line"
    ip="$(trim "$ip")"; func="$(trim "$func")"
    (
      # -f forces copy even if the key is already present (idempotent)
      if sshpass -e ssh-copy-id -f -i "$pub_key" \
          "${SSH_OPTS[@]}" "${username}@${ip}"; then
        printf "ok:%s:%s\n"   "$func" "$ip" >"$tmpdir/${func//\//_}.result"
      else
        printf "fail:%s:%s\n" "$func" "$ip" >"$tmpdir/${func//\//_}.result"
      fi
    ) >/dev/null 2>&1 &
    pids+=($!)
  done

  shopt -s nullglob
  local done_count=0
  while (( done_count < total )); do
    local result_files=("$tmpdir"/*.result)
    done_count="${#result_files[@]}"
    progress_bar "$done_count" "$total" "copying keys..."
    sleep 0.25
  done
  shopt -u nullglob
  echo

  for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  local ok=0 fail=0 result_file
  for result_file in "$tmpdir"/*.result; do
    [[ -f "$result_file" ]] || continue
    local result; result="$(cat "$result_file")"
    case "$result" in
      ok:*)   ok=$(( ok + 1 )) ;;
      fail:*) fail=$(( fail + 1 ))
              local fhost; fhost="${result#fail:}"
              log_warn "${fhost%%:*} (${fhost##*:}): key install failed" ;;
    esac
  done

  if (( fail == 0 )); then
    log_ok "SSH key installed on ${ok}/${total} hosts."
  else
    log_warn "Key install — ${ok}/${total} OK, ${fail} failed."
  fi
}

# ────────────────────────────── Terminal launcher ───────────────────────────
# Receives a path to a self-contained bash script and opens it in the first
# available GUI terminal emulator.
# Passing a script file (rather than a command string) avoids the nested-quote
# fragility that broke the previous bash -lc "..." approach.
# Returns 1 if no supported GUI terminal is found.
open_ssh_terminal() {
  local title="$1" script="$2"

  if command -v gnome-terminal >/dev/null 2>&1; then
    # Try with --title (older gnome-terminal); fall back without it (newer builds
    # dropped the flag — they return non-zero on unrecognised options).
    { gnome-terminal --title="$title" -- bash "$script" 2>/dev/null \
        || gnome-terminal -- bash "$script" 2>/dev/null; } &
    return 0
  fi
  if command -v xterm >/dev/null 2>&1; then
    xterm -T "$title" -e bash "$script" >/dev/null 2>&1 &
    return 0
  fi
  if command -v konsole >/dev/null 2>&1; then
    konsole -p tabtitle="$title" -e bash "$script" >/dev/null 2>&1 &
    return 0
  fi
  if command -v alacritty >/dev/null 2>&1; then
    alacritty --title "$title" -e bash "$script" >/dev/null 2>&1 &
    return 0
  fi
  if command -v wezterm >/dev/null 2>&1; then
    wezterm start --class "$title" bash "$script" >/dev/null 2>&1 &
    return 0
  fi
  if command -v x-terminal-emulator >/dev/null 2>&1; then
    x-terminal-emulator -T "$title" -e bash "$script" >/dev/null 2>&1 &
    return 0
  fi

  rm -f "$script"   # clean up — script won't self-delete if never run
  return 1
}

# ─────────────────────────────────── SSH menu ───────────────────────────────
ssh_menu() {
  ensure_hosts
  ensure_creds   # ensures SSHPASS is exported

  mapfile -t hosts < <(read_hosts)
  local total="${#hosts[@]}"
  (( total > 0 )) || die "No hosts found in $HOSTS_FILE"

  echo
  local i=0 line ip func
  for line in "${hosts[@]}"; do
    i=$(( i + 1 ))
    IFS=',' read -r ip func <<<"$line"
    ip="$(trim "$ip")"; func="$(trim "$func")"
    printf "  %2d) %-22s %s\n" "$i" "${func:-HOST}" "$ip"
  done

  echo
  read -r -p "  Select host number (or q): " sel
  [[ "$sel" == "q" || "$sel" == "Q" ]] && return 0
  [[ "$sel" =~ ^[0-9]+$ ]] || { log_warn "Invalid selection"; return 0; }
  (( sel >= 1 && sel <= total )) || { log_warn "Selection out of range"; return 0; }

  IFS=',' read -r ip func <<<"${hosts[$(( sel - 1 ))]}"
  ip="$(trim "$ip")"; func="$(trim "$func")"

  # Write a self-contained, self-deleting SSH session script.
  # Using a temp file avoids all nested-quoting issues when passing the SSH
  # command (with its many -o options) to a GUI terminal emulator.
  local tmp_script; tmp_script="$(mktemp --suffix=.sh)"
  chmod 700 "$tmp_script"
  {
    printf '#!/usr/bin/env bash\n'
    printf 'export SSHPASS=%q\n' "$SSHPASS"
    # Set the new terminal window's title to the host function name
    printf 'printf "\\033]0;%s\\007"\n' "${func:-HOST}"
    printf 'sshpass -e ssh'
    printf ' %q' "${SSH_OPTS[@]}"
    printf ' %q\n' "${username}@${ip}"
    printf 'echo\n'
    printf "printf '[lab-speed] session ended\\\\n'\n"
    printf "read -r -p 'Press Enter to close...' _\n"
    printf 'rm -f -- %q\n' "$tmp_script"
  } >"$tmp_script"

  # Update this terminal's title to reflect the active host
  printf '\033]0;%s\007' "${func:-HOST}"

  if open_ssh_terminal "${func:-HOST}" "$tmp_script"; then
    log_ok "Opened SSH in a new terminal: ${func:-HOST} ($ip)"
    printf '\033]0;lab-speed\007'   # restore title
    return 0
  fi

  # No GUI terminal available — open SSH directly in this window.
  # Direct array call: no eval, no shell injection risk.
  log "INFO" "No GUI terminal found — opening SSH in this window."
  sshpass -e ssh "${SSH_OPTS[@]}" "${username}@${ip}"
  printf '\033]0;lab-speed\007'
  rm -f "$tmp_script"
}

# ──────────────────────────────────── Cleanup ───────────────────────────────
cleanup() {
  rm -f "$CREDS_FILE"
  log_ok "Deleted $CREDS_FILE"
}

# ─────────────────────────────────── Main menu ──────────────────────────────
menu() {
  rotate_logs

  while true; do
    header
    printf "  %s\n" "1) GO!  (RSYNC files to all hosts)"
    printf "  %s\n" "2) SSH  (open host session)"
    printf "  %s\n" "3) RSYNC again"
    printf "  %s\n" "4) Install SSH keys to all hosts"
    printf "  %s\n" "5) Dependency check"
    printf "  %s\n" "7) Clean Up (delete creds)"
    printf "  %s\n" "q) Quit"
    echo
    read -r -p "  Select an option: " opt
    case "$opt" in
      1) go_run;            read -r -p "  Press Enter to return to menu..." _ ;;
      2) ssh_menu;          read -r -p "  Press Enter to return to menu..." _ ;;
      3) rsync_only;        read -r -p "  Press Enter to return to menu..." _ ;;
      4) install_ssh_keys;  read -r -p "  Press Enter to return to menu..." _ ;;
      5) ensure_hosts; ensure_creds; check_deps
                            read -r -p "  Press Enter to return to menu..." _ ;;
      7) cleanup;           read -r -p "  Press Enter to return to menu..." _ ;;
      q|Q) exit 0 ;;
      *) log_warn "Invalid option"; sleep 0.5 ;;
    esac
  done
}

menu
